---
import { getTranslations, getSiteData, type Language } from '../data/site';

export interface Props {
  language: Language;
}

const { language } = Astro.props;
const t = await getTranslations(language);
const siteData = await getSiteData();
---

<section id="ubicacion" class="py-24 px-6 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="grid lg:grid-cols-3 gap-12 items-center">
      <div class="lg:col-span-1">
        <span class="text-emerald-700 uppercase tracking-widest text-sm font-bold mb-4 block">
          {t.location.tag}
        </span>
        <h2 class="text-4xl font-serif text-emerald-950 mb-8">
          {t.location.title} <br />
          <span class="italic">{t.location.titleItalic}</span>
        </h2>
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="bg-emerald-50 p-3 rounded-2xl text-emerald-700 h-fit">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <h4 class="font-bold text-emerald-900 mb-1">{t.location.address}</h4>
              <p class="text-emerald-900/60 text-sm">
                {siteData.contact.address} <br />
                {t.location.beach}
              </p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="bg-emerald-50 p-3 rounded-2xl text-emerald-700 h-fit">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
            </div>
            <div>
              <h4 class="font-bold text-emerald-900 mb-1">{t.location.airport}</h4>
              <p class="text-emerald-900/60 text-sm">
                {siteData.airport.name} ({siteData.airport.code}) - {siteData.airport.distance}. {t.location.airportDesc}
              </p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="bg-emerald-50 p-3 rounded-2xl text-emerald-700 h-fit">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            </div>
            <div>
              <h4 class="font-bold text-emerald-900 mb-1">{t.location.nearby}</h4>
              <p class="text-emerald-900/60 text-sm">
                {t.location.nearbyDesc}
              </p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="lg:col-span-2 rounded-3xl overflow-hidden shadow-2xl h-[500px]">
        <iframe 
          src={siteData.images.mapEmbed} 
          width="100%" 
          height="100%" 
          style="border: 0" 
          allowfullscreen="true" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>
</section>
