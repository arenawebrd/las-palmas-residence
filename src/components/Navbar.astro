---
import { getTranslations, getSiteData, type Language } from '../data/site';
import LanguageSwitcher from './LanguageSwitcher.astro';

export interface Props {
  language: Language;
}

const { language } = Astro.props;
const t = await getTranslations(language);
const siteData = await getSiteData();

const navLinks = [
  { name: t.nav.hotel, href: '#hotel' },
  { name: t.nav.rooms, href: '#alojamientos' },
  { name: t.nav.services, href: '#servicios' },
  { name: t.nav.gallery, href: '#galeria' },
  { name: t.nav.location, href: '#ubicacion' },
  { name: t.nav.contact, href: '#contacto' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 px-6 py-3">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <a href="#" class="flex items-center gap-2 group">
      <svg class="w-7 h-7 text-white nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M13 8c0-2.76-2.46-5-5.5-5S2 5.24 2 8h2l1-1 1 1h4"/>
        <path d="M13 7.14A5.82 5.82 0 0 1 16.5 6c3.04 0 5.5 2.24 5.5 5h-3l-1-1-1 1h-3"/>
        <path d="M5.89 9.71c-2.15 2.15-2.3 5.47-.35 7.43l4.24-4.25.7-.7.71-.71 2.12-2.12c-1.95-1.96-5.27-1.8-7.42.35z"/>
        <path d="M11 15.5c.5 2.5-.17 4.5-1 6.5h4c2-5.5-.5-12-1-14"/>
        <path d="M13 19c2.5 0 3.5-1 5-2"/>
      </svg>
      <span class="font-serif text-lg font-semibold tracking-tight text-white nav-text">
        {siteData.site.name}
      </span>
    </a>

    <div class="hidden md:flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-base font-medium hover:bg-white/10 px-3 py-2 rounded-full transition-all text-white nav-link"
        >
          {link.name}
        </a>
      ))}
      
      <LanguageSwitcher language={language} />
    </div>

    <div class="flex items-center gap-3 md:hidden">
      <LanguageSwitcher language={language} />
      <button id="mobile-menu-btn" class="text-white p-2 rounded-full hover:bg-white/10 transition-colors">
        <svg class="w-6 h-6 nav-mobile-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden absolute top-full left-0 right-0 bg-white shadow-lg py-4 px-6 flex flex-col gap-2 md:hidden rounded-b-2xl">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="text-emerald-900 font-medium py-3 px-4 rounded-xl hover:bg-emerald-50 transition-colors mobile-link"
      >
        {link.name}
      </a>
    ))}
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  function updateNavbar() {
    const isScrolled = window.scrollY > 50;
    const links = navbar?.querySelectorAll('.nav-link');
    const navText = navbar?.querySelector('.nav-text');
    const navIcon = navbar?.querySelector('.nav-icon');
    const langBtns = navbar?.querySelectorAll('.lang-btn');
    const navBtn = navbar?.querySelector('.nav-btn');
    const mobileIcon = navbar?.querySelector('.nav-mobile-icon');
    
    if (isScrolled) {
      navbar?.classList.add('bg-white/90', 'backdrop-blur-md', 'shadow-sm', 'py-3');
      navbar?.classList.remove('bg-transparent');
      links?.forEach(l => {
        l.classList.add('text-emerald-900');
        l.classList.remove('text-white');
      });
      navText?.classList.add('text-emerald-900');
      navText?.classList.remove('text-white');
      navIcon?.classList.add('text-emerald-700');
      navIcon?.classList.remove('text-white');
      langBtns?.forEach(btn => {
        btn.classList.add('lang-btn-scrolled');
        btn.classList.remove('lang-btn-transparent');
        (btn as HTMLElement).style.borderColor = 'rgba(5, 150, 105, 0.2)';
        (btn as HTMLElement).style.color = '#065f46';
      });
      navBtn?.classList.add('bg-emerald-700', 'text-white');
      navBtn?.classList.remove('bg-white', 'text-emerald-900');
      mobileIcon?.classList.add('text-emerald-900');
      mobileIcon?.classList.remove('text-white');
    } else {
      navbar?.classList.remove('bg-white/90', 'backdrop-blur-md', 'shadow-sm', 'py-3');
      navbar?.classList.add('bg-transparent');
      links?.forEach(l => {
        l.classList.remove('text-emerald-900');
        l.classList.add('text-white');
      });
      navText?.classList.remove('text-emerald-900');
      navText?.classList.add('text-white');
      navIcon?.classList.remove('text-emerald-700');
      navIcon?.classList.add('text-white');
      langBtns?.forEach(btn => {
        btn.classList.remove('lang-btn-scrolled');
        btn.classList.add('lang-btn-transparent');
        (btn as HTMLElement).style.borderColor = 'rgba(255,255,255,0.2)';
        (btn as HTMLElement).style.color = 'white';
      });
      navBtn?.classList.remove('bg-emerald-700', 'text-white');
      navBtn?.classList.add('bg-white', 'text-emerald-900');
      mobileIcon?.classList.remove('text-emerald-900');
      mobileIcon?.classList.add('text-white');
    }
  }

  window.addEventListener('scroll', updateNavbar);
  updateNavbar();

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
