---
import '../styles/global.css';
import { getSiteData } from '../data/site';

export interface Props {
  title?: string;
  language?: 'es' | 'en';
}

const { 
  title = 'Las Palmas Eco Residence',
  language = 'es' 
} = Astro.props;

const siteData = await getSiteData();
---

<!doctype html>
<html lang={language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteData.site.description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css" />
  </head>
  <body class="min-h-screen">
    <slot />
    <a 
      href={`https://wa.me/${siteData.contact.phoneRaw}?text=Hola,%20me%20gustaria%20reservar`}
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 bg-green-500 hover:bg-green-600 text-white p-4 rounded-full shadow-2xl z-50 transition-transform hover:scale-110 flex items-center justify-center"
      aria-label="WhatsApp"
    >
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M17.498 14.382c-.301-.149-1.767-.867-2.04-.98-.273-.094-.476-.125-.676.173-.2.296-.651.972-.799 1.177-.149.209-.297.223-.545.074-.248-.151-1.045-.485-1.987-1.558-.935-.935-1.587-2.08-1.678-2.435-.094-.354-.08-.31.063-.645.149-.337.297-.354.398-.354l.338.079.298-.089-.238.238c.198.487.551.894.955 1.21l.146.114c.281.226 1.426.314 1.912.095.485-.218 1.167-.569 1.32-1.13.15-.562-.025-1.157-.401-1.534l-.474-.474c-.133-.133-.292-.347-.437-.189zM12.003 0C5.373 0 .5 4.873.5 10.6c0 1.903 1.14 3.61 3.03 4.91l-.53 1.737 1.422-.493c1.554.849 3.306 1.296 5.13 1.44.063.003.125.005.189.005 4.799 0 8.64-3.909 8.64-8.733C20.37 4.914 15.373 0 12.003 0zM8.073 8.235c.337-.049.689.121.939.371l.146.146c.178.178.357.448.327.694-.03.266-.151.589-.2.756-.052.174-.173.297-.347.446-.149.124-.322.266-.099.523.223.256 1.003.835 2.175 1.381 1.381.646 2.413 1.013 2.793 1.18.38.166.609.27.609.523.026.256-.193.579-.495.908-.302.329-.69.741-.765.836-.097.124-.24.124-.337.124-.126-.016-.266-.016-.395-.016.987-.385 2.004-1.08 2.728-1.908.724-.828 1.214-1.824 1.458-2.908.097-.33.097-.69.074-1.004-.024-.351-.297-.59-.676-.908-.379-.318-.835-.494-1.213-.679l-.474-.238c-.487-.244-1.002-.415-1.534-.495-.38-.054-.692-.054-1.05-.054l-.659.025c-.063.025-.126.025-.198.025z"/></svg>
    </a>
  </body>
</html>
