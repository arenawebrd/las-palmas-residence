---
import '../styles/global.css';
import { getSiteData } from '../data/site';

export interface Props {
  title?: string;
  language?: 'es' | 'en';
}

const { 
  title = 'Las Palmas Eco Residence',
  language = 'es' 
} = Astro.props;

const siteData = await getSiteData();
---

<!doctype html>
<html lang={language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteData.site.description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css" />
  </head>
  <body class="min-h-screen">
    <slot />
    <a 
      href={`https://wa.me/${siteData.contact.phoneRaw}?text=Hola,%20me%20gustaria%20reservar`}
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 bg-green-500 hover:bg-green-600 text-white p-4 rounded-full shadow-2xl z-50 transition-transform hover:scale-110 flex items-center justify-center"
      aria-label="WhatsApp"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
        <path d="M17.545 15.467A8.412 8.412 0 0 1 12 20.125c-2.3 0-4.463-.945-6.082-2.558a8.414 8.414 0 0 1-2.558-6.082c0-2.3.945-4.463 2.558-6.082a8.413 8.413 0 0 1 6.082-2.558c2.3 0 4.463.945 6.082 2.558a8.414 8.414 0 0 1 2.558 6.082c0 2.3-.945 4.463-2.558 6.082zM12 2.125c-2.178 0-4.235.858-5.78 2.355a7.445 7.445 0 0 0-2.27 5.145c0 1.937.78 3.757 2.027 5.109l.268.268.073.073a7.982 7.982 0 0 0 3.41 2.172c1.05.34 2.163.52 3.282.52 2.178 0 4.235-.858 5.78-2.355a7.445 7.445 0 0 0 2.27-5.145c0-1.937-.78-3.757-2.027-5.109l-.268-.268-.073-.073a7.982 7.982 0 0 0-3.41-2.172c-1.05-.34-2.163-.52-3.282-.52zM15.5 7.625a1.125 1.125 0 1 0 0-2.25 1.125 1.125 0 0 0 0 2.25zm-4.5 0a1.125 1.125 0 1 0 0-2.25 1.125 1.125 0 0 0 0 2.25zm-4.5 0a1.125 1.125 0 1 0 0-2.25 1.125 1.125 0 0 0 0 2.25z"/>
      </svg>
    </a>
  </body>
</html>
